# Server Configuration
NODE_ENV=development
PORT=3000

# Database - Docker PostgreSQL (RECOMMENDED for local development)
# Start database with: docker compose up -d
DATABASE_URL=postgresql://opexsales_user:secure_password@localhost:5432/opexsales

# Alternative: Local PostgreSQL Installation
# DATABASE_URL=postgresql://username:password@localhost:5432/opexsales

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_minimum_32_characters_recommended
JWT_EXPIRATION=900s
REFRESH_TOKEN_SECRET=your_super_secret_refresh_token_key_minimum_32_characters
REFRESH_TOKEN_EXPIRATION=7d

# CORS & URLs
FRONTEND_URL=http://localhost:8080
BACKEND_URL=http://localhost:3000

# OpenAI API Configuration
OPENAI_API_KEY=sk-your-api-key-here
OPENAI_MODEL=gpt-4-turbo-preview

# SendGrid Email Webhook Integration (Optional)
SENDGRID_API_KEY=SG.your-sendgrid-api-key
SENDGRID_WEBHOOK_SECRET=whsec_your_sendgrid_webhook_secret

# Twilio SMS Webhook Integration (Optional)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_WEBHOOK_TOKEN=your-webhook-token

# Mailgun Email Alternative (Optional)
MAILGUN_API_KEY=key-your-mailgun-api-key
MAILGUN_DOMAIN=sandbox.mailgun.org

# Logging
LOG_LEVEL=debug
